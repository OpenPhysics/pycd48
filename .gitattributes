# Force LF line endings for executable scripts
*.sh text eol=lf

# Python source must use LF (shebang scripts run on WSL/Linux)
*.py text eol=lf

# Default: normalize to LF in the repo
* text=auto eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
